{
    "name": "mmi/mmi",
    "type": "library",
    "description": "MMi Framework Library",
    "keywords": ["mmi", "framework"],
    "license": "MIT",
    "authors": [
        {
            "name": "Mariusz Miłejko",
            "email": "mariusz@milejko.pl"
        },
        {
            "name": "Bartłomiej Wołos",
            "email": "funfel@onet.pl"
        },
        {
            "name": "Maciej Pawłowski",
            "email": "mac@macu.eu"
        },
        {
            "name": "Krystian Gapski",
            "email": "k.gapski@nowaera.pl"
        },
        {
            "name": "Robert Pawłowski",
            "email": "r.pawlowski@nowaera.pl"
        }
    ],
    "require": {
        "php": ">=8.3.0",
        "ext-bcmath": "*",
        "ext-date": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-hash": "*",
        "ext-iconv": "*",
        "ext-json": "*",
        "ext-ldap": "*",
        "ext-mbstring": "*",
        "ext-pcre": "*",
        "ext-pdo": "*",
        "ext-reflection": "*",
        "ext-session": "*",
        "ext-spl": "*",
        "monolog/monolog": "1.*",
        "graylog2/gelf-php": "1.5.*",
        "php-di/php-di": "^7.0",
        "symfony/console": "^5.0",
        "symfony/dotenv": "^5.0"
    },
    "scripts": {
        "fix:phpcbf": "phpcbf",
        "fix:php-cs-fixer": "php-cs-fixer fix src && php-cs-fixer fix tests",
        "fix:all": [
            "@fix:phpcbf",
            "@fix:php-cs-fixer"
        ],
        "report:metrics": "phpmetrics --report-html=./web/build/metrics ./src",
        "test:security-checker": "security-checker security:check",
        "test:phpstan": "XDEBUG_MODE=off phpstan --level=1 --no-progress --memory-limit=512M analyse src tests -c phpstan.neon",
        "test:phpcs": "phpcs",
        "test:phpmd": "php -d error_reporting=8191 vendor/bin/phpmd ./src text phpmd.xml.dist",
        "test:phpunit": "XDEBUG_MODE=coverage phpunit --coverage-clover ./.phpunit.coverage.clover.xml --coverage-html ./web/build/phpunit",
        "test:infection": "XDEBUG_MODE=off infection --no-progress --only-covered --threads=max",
        "test:all": [
            "@test:security-checker",
            "@test:phpcs",
            "@test:phpstan",
            "@test:phpmd",
            "@test:phpunit"
        ]
    },
    "autoload": {
        "psr-4": {
            "Mmi\\": "src/Mmi",
            "": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Mmi\\": "tests/Mmi"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "4.1-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true,
            "php-http/discovery": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpmd/phpmd": "^2.13",
        "squizlabs/php_codesniffer": "^3.7",
        "enlightn/security-checker": "*",
        "php-http/mock-client": "^1.5",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.12",
        "phpstan/phpstan-phpunit": "^2.0"
    }
}
